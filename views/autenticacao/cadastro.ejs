<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title><%= titulo %> | Súmula</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="pagina-login">
    <main class="login-container">
        <section class="login-caixa">
            <div class="login-cabecalho">
                <span class="login-logo">⚽</span>

                <h1>Criar conta</h1>

                <p>
                    Cadastre-se para acessar o sistema.
                </p>
            </div>

            <% if (erro) { %>
                <div class="mensagem erro">
                    <%= erro %>
                </div>
            <% } %>

            <form action="/cadastro" method="POST">
                <div class="campo">
                    <label for="nome">Nome</label>

                    <input
                        type="text"
                        id="nome"
                        name="nome"
                        maxlength="100"
                        value="<%= dados.nome || '' %>"
                        required
                    >
                </div>

                <div class="campo">
                    <label for="email">E-mail</label>

                    <input
                        type="email"
                        id="email"
                        name="email"
                        maxlength="100"
                        value="<%= dados.email || '' %>"
                        autocomplete="email"
                        required
                    >
                </div>

                <div class="campo">
                    <label for="senha">Senha</label>

                    <input
                        type="password"
                        id="senha"
                        name="senha"
                        minlength="6"
                        autocomplete="new-password"
                        required
                    >
                </div>

                <div class="campo">
                    <label for="confirmar_senha">
                        Confirmar senha
                    </label>

                    <input
                        type="password"
                        id="confirmar_senha"
                        name="confirmar_senha"
                        minlength="6"
                        autocomplete="new-password"
                        required
                    >
                </div>

                <button
                    class="botao botao-login"
                    type="submit"
                >
                    Cadastrar
                </button>
            </form>

            <p class="login-link">
                Já possui uma conta?
                <a href="/login">Entrar</a>
            </p>
        </section>
    </main>
</body>
</html>