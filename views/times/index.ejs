<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title><%= titulo %> | Central do Campeonato</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <header class="topo topo-interna">
        <div class="marca">
            <a class="logo-link" href="/">
                <span class="logo">⚽</span>
            </a>
            <div>
                <h1>Central do Campeonato</h1>
                <p>Gerenciamento de campeonatos de futebol</p>
            </div>
        </div>
    </header>

    <main>
        <nav class="trilha">
            <a href="/">Início</a> <span>/</span> <span>Times</span>
        </nav>

        <div class="barra-titulo">
            <div>
                <h2>Times</h2>
                <p>Times cadastrados no sistema.</p>
            </div>

            <a class="botao" href="/times/novo">
                + Novo time
            </a>
        </div>

        <% if (sucesso) { %>
            <div class="mensagem sucesso">
                Time cadastrado com sucesso.
            </div>
        <% } %>

        <section class="conteudo">
            <% if (times.length === 0) { %>
                <div class="vazio">
                    <span class="vazio-icone">🛡️</span>
                    <p>Nenhum time cadastrado.</p>
                    <a class="botao" href="/times/novo">Cadastrar o primeiro</a>
                </div>
            <% } else { %>
                <table>
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Cidade</th>
                            <th>Estado</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% times.forEach((time) => { %>
                            <tr>
                                <td class="celula-forte"><%= time.nome %></td>
                                <td><%= time.cidade %></td>
                                <td><%= time.estado %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </section>

        <p class="voltar">
            <a href="/">← Voltar para a página inicial</a>
        </p>
    </main>
</body>
</html>
