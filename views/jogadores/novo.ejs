<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title><%= titulo %> | Central do Campeonato</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <header class="topo topo-interna">
        <div class="marca">
            <a class="logo-link" href="/">
                <span class="logo">⚽</span>
            </a>
            <div>
                <h1>Central do Campeonato</h1>
                <p>Cadastro de jogador</p>
            </div>
        </div>
    </header>

    <main>
        <nav class="trilha">
            <a href="/">Início</a> <span>/</span>
            <a href="/jogadores">Jogadores</a> <span>/</span>
            <span>Novo</span>
        </nav>

        <section class="conteudo conteudo-form">
            <h2>Novo jogador</h2>

            <% if (erro) { %>
                <div class="mensagem erro">
                    <%= erro %>
                </div>
            <% } %>

            <form action="/jogadores" method="POST">
                <div class="campo">
                    <label for="nome">Nome</label>

                    <input
                        type="text"
                        id="nome"
                        name="nome"
                        maxlength="150"
                        value="<%= dados.nome || '' %>"
                        required
                    >
                </div>

                <div class="grade-campos">
                    <div class="campo">
                        <label for="data_nascimento">
                            Data de nascimento
                        </label>

                        <input
                            type="date"
                            id="data_nascimento"
                            name="data_nascimento"
                            value="<%= dados.data_nascimento || '' %>"
                            required
                        >
                    </div>

                    <div class="campo">
                        <label for="posicao">Posição</label>

                        <select
                            id="posicao"
                            name="posicao"
                            required
                        >
                            <option value="">Selecione</option>

                            <% posicoes.forEach((posicao) => { %>
                                <option
                                    value="<%= posicao %>"
                                    <%= dados.posicao === posicao
                                        ? 'selected'
                                        : '' %>
                                >
                                    <%= posicao %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="acoes">
                    <button class="botao" type="submit">
                        Cadastrar
                    </button>

                    <a
                        class="botao secundario"
                        href="/jogadores"
                    >
                        Cancelar
                    </a>
                </div>
            </form>
        </section>
    </main>
</body>
</html>
