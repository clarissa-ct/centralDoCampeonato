<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title><%= titulo %> | Central do Campeonato</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <header class="topo topo-interna">
        <div class="marca">
            <a class="logo-link" href="/">
                <span class="logo">⚽</span>
            </a>
            <div>
                <h1>Central do Campeonato</h1>
                <p>Classificação do campeonato</p>
            </div>
        </div>
    </header>

    <main>
        <nav class="trilha">
            <a href="/">Início</a> <span>/</span>
            <a href="/consultas">Consultas</a> <span>/</span>
            <span>Classificação</span>
        </nav>

        <div class="barra-titulo">
            <div>
                <h2>Classificação</h2>

                <p>
                    <%= campeonato.nome %>
                    -
                    <%= campeonato.ano %>
                </p>
            </div>
        </div>

        <section class="conteudo">
            <% if (classificacao.length === 0) { %>
                <div class="vazio">
                    <span class="vazio-icone">📊</span>
                    <p>Nenhum time inscrito neste campeonato.</p>
                </div>
            <% } else { %>
                <div class="tabela-responsiva">
                    <table class="tabela-classificacao">
                        <thead>
                            <tr>
                                <th>Pos.</th>
                                <th>Time</th>
                                <th>J</th>
                                <th>V</th>
                                <th>E</th>
                                <th>D</th>
                                <th>GP</th>
                                <th>GC</th>
                                <th>SG</th>
                                <th>P</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% classificacao.forEach(
                                (item, indice) => {
                            %>
                                <tr class="<%= indice < 4 ? 'linha-classificado' : '' %>">
                                    <td>
                                        <span class="posicao posicao-<%= indice + 1 %>">
                                            <%= indice + 1 %>
                                        </span>
                                    </td>
                                    <td class="celula-forte"><%= item.time %></td>
                                    <td><%= item.jogos %></td>
                                    <td><%= item.vitorias %></td>
                                    <td><%= item.empates %></td>
                                    <td><%= item.derrotas %></td>
                                    <td><%= item.gols_pro %></td>
                                    <td><%= item.gols_contra %></td>
                                    <td><%= item.saldo_gols %></td>
                                    <td>
                                        <strong class="pontos">
                                            <%= item.pontos %>
                                        </strong>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>

        <div class="acoes">
            <a class="botao secundario" href="/consultas">
                Voltar para consultas
            </a>

            <a class="botao secundario" href="/">
                Página inicial
            </a>
        </div>
    </main>
</body>
</html>
