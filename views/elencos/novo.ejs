<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title><%= titulo %> | Central do Campeonato</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <header class="topo topo-interna">
        <div class="marca">
            <a class="logo-link" href="/">
                <span class="logo">⚽</span>
            </a>
            <div>
                <h1>Central do Campeonato</h1>
                <p>Montagem dos elencos</p>
            </div>
        </div>
    </header>

    <main>
        <nav class="trilha">
            <a href="/">Início</a> <span>/</span>
            <a href="/elencos">Elencos</a> <span>/</span>
            <span>Novo</span>
        </nav>

        <section class="conteudo conteudo-form">
            <h2>Adicionar jogador ao elenco</h2>

            <% if (erro) { %>
                <div class="mensagem erro">
                    <%= erro %>
                </div>
            <% } %>

            <% if (
                inscricoes.length === 0 ||
                jogadores.length === 0
            ) { %>
                <div class="mensagem erro">
                    É necessário possuir times inscritos e
                    jogadores cadastrados.
                </div>
            <% } else { %>
                <form action="/elencos" method="POST">
                    <div class="campo">
                        <label for="inscricao">
                            Campeonato e time
                        </label>

                        <select
                            id="inscricao"
                            name="inscricao"
                            required
                        >
                            <option value="">Selecione</option>

                            <% inscricoes.forEach((item) => { %>
                                <% const valor =
                                    item.id_campeonato
                                    + ':'
                                    + item.id_time;
                                %>

                                <option
                                    value="<%= valor %>"
                                    <%= dados.inscricao === valor
                                        ? 'selected'
                                        : '' %>
                                >
                                    <%= item.campeonato %>
                                    -
                                    <%= item.ano %>
                                    |
                                    <%= item.time %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="campo">
                        <label for="id_jogador">
                            Jogador
                        </label>

                        <select
                            id="id_jogador"
                            name="id_jogador"
                            required
                        >
                            <option value="">Selecione</option>

                            <% jogadores.forEach((jogador) => { %>
                                <option
                                    value="<%= jogador.id_jogador %>"
                                    <%= String(dados.id_jogador)
                                        === String(jogador.id_jogador)
                                        ? 'selected'
                                        : '' %>
                                >
                                    <%= jogador.nome %>
                                    -
                                    <%= jogador.posicao %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="campo campo-estreito">
                        <label for="numero_camisa">
                            Número da camisa
                        </label>

                        <input
                            type="number"
                            id="numero_camisa"
                            name="numero_camisa"
                            min="1"
                            max="99"
                            step="1"
                            value="<%= dados.numero_camisa || '' %>"
                            required
                        >
                    </div>

                    <div class="acoes">
                        <button class="botao" type="submit">
                            Adicionar ao elenco
                        </button>

                        <a
                            class="botao secundario"
                            href="/elencos"
                        >
                            Cancelar
                        </a>
                    </div>
                </form>
            <% } %>
        </section>
    </main>
</body>
</html>
