<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title><%= titulo %> | Central do Campeonato</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <header class="topo topo-interna">
        <div class="marca">
            <a class="logo-link" href="/">
                <span class="logo">⚽</span>
            </a>
            <div>
                <h1>Central do Campeonato</h1>
                <p>Gerenciamento de campeonatos de futebol</p>
            </div>
        </div>
    </header>

    <main>
        <nav class="trilha">
            <a href="/">Início</a> <span>/</span> <span>Elencos</span>
        </nav>

        <div class="barra-titulo">
            <div>
                <h2>Elencos</h2>
                <p>Jogadores vinculados aos times.</p>
            </div>

            <a class="botao" href="/elencos/novo">
                + Adicionar jogador
            </a>
        </div>

        <% if (sucesso) { %>
            <div class="mensagem sucesso">
                Jogador adicionado ao elenco com sucesso.
            </div>
        <% } %>

        <section class="conteudo">
            <% if (elencos.length === 0) { %>
                <div class="vazio">
                    <span class="vazio-icone">👥</span>
                    <p>Nenhum jogador vinculado a um elenco.</p>
                    <a class="botao" href="/elencos/novo">Adicionar o primeiro</a>
                </div>
            <% } else { %>
                <table>
                    <thead>
                        <tr>
                            <th>Campeonato</th>
                            <th>Ano</th>
                            <th>Time</th>
                            <th>Camisa</th>
                            <th>Jogador</th>
                            <th>Posição</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% elencos.forEach((elenco) => { %>
                            <tr>
                                <td><%= elenco.campeonato %></td>
                                <td><%= elenco.ano %></td>
                                <td><%= elenco.time %></td>
                                <td>
                                    <span class="numero-camisa">
                                        <%= elenco.numero_camisa %>
                                    </span>
                                </td>
                                <td class="celula-forte"><%= elenco.jogador %></td>
                                <td>
                                    <span class="badge badge-posicao">
                                        <%= elenco.posicao %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </section>

        <p class="voltar">
            <a href="/">← Voltar para a página inicial</a>
        </p>
    </main>
</body>
</html>
